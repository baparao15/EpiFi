# Leave blank (or unset) for local dev — Vite's dev-server proxy in vite.config.js
# forwards /api/* to BACKEND_URL (default http://localhost:8787).
#
# For a production build where the frontend is hosted separately from the backend,
# set this to your deployed backend's base URL (no trailing slash):
VITE_API_URL=https://your-backend-host.example.com
