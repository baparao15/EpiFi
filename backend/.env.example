# Use GROQ_API_KEYS for automatic rotation across multiple keys (recommended if you have
# several, e.g. to avoid one key's rate limit stalling requests):
GROQ_API_KEYS=key_one,key_two,key_three

# Or, if you only have one key, GROQ_API_KEY also works:
# GROQ_API_KEY=your_groq_api_key_here

GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
PORT=8787
